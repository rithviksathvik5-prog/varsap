# ── Copy this file to .env.local and fill in every value. ──────────────

# MongoDB Atlas (free M0 tier) — Database > Connect > Drivers
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="varsap"

# NextAuth — generate with:  npx auth secret
AUTH_SECRET=""
# Google OAuth client (console.cloud.google.com > APIs & Services > Credentials)
# Authorized redirect URI:  https://YOUR-DOMAIN/api/auth/callback/google
#                    (dev:  http://localhost:3000/api/auth/callback/google)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Who may sign in: anyone on this domain…
ALLOWED_EMAIL_DOMAIN="varistor.in"
# …plus this comma-separated whitelist of extra addresses
ALLOWED_EMAILS="rkkilari@gmail.com"

# Upstash QStash (console.upstash.com > QStash) — all three values shown there
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Public base URL of THIS deployment — QStash calls back to it.
# On Vercel this can be omitted (VERCEL_URL is used automatically).
APP_URL="https://your-app.vercel.app"

# Meta WhatsApp Cloud API (developers.facebook.com > your app > WhatsApp > API Setup)
META_ACCESS_TOKEN=""
META_PHONE_NUMBER_ID=""
# The approved template's exact name + language code
META_TEMPLATE_NAME="feedback_request"
META_TEMPLATE_LANG="en"
# Any random string — enter the same value when subscribing the webhook in Meta
META_WEBHOOK_VERIFY_TOKEN=""
# App secret (App Settings > Basic) — enables webhook signature verification
META_APP_SECRET=""

# Pre-flight cost estimator: INR per marketing template conversation (India)
NEXT_PUBLIC_COST_PER_MESSAGE_INR="0.88"
